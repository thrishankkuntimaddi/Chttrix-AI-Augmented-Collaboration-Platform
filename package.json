{
  "name": "chttrix-collab",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "npm run dev",
    "dev": "npm run server & npm run client",
    "client": "cd client && npm start",
    "server": "cd server && npm run dev",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "mongoose": "^9.1.1"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6"
  }
}
