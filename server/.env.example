# Server Configuration
PORT=8080
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chttrix?retryWrites=true&w=majority

# JWT Configuration (REQUIRED - generate secure secrets)
ACCESS_TOKEN_SECRET=your_access_token_secret_here_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# URLs (REQUIRED)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# Email Configuration (for invites, password resets)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
EMAIL_FROM=noreply@example.com

# OAuth Configuration (REQUIRED for Google login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth (Optional - only if using these providers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Twilio Configuration (Optional - for OTP SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# E2EE Configuration (REQUIRED for encryption features)
SERVER_KEK=your_64_character_hex_key_for_server_encryption
CRYPTO_KEK_ACTIVE_VERSION=1
CRYPTO_KEK_V1=your_64_character_hex_key_version_1
CRYPTO_KEK_V2=your_64_character_hex_key_version_2

# AI Features (Optional)
GEMINI_API_KEY=your_gemini_api_key

# Email Service (Optional - Brevo/SendInBlue)
BREVO_API_KEY=your_brevo_api_key

# Redis (Optional - for horizontal scaling across multiple server instances)
# When set: Socket.IO uses Redis pub/sub — events propagate across all instances.
# When unset: server runs in single-instance mode (safe for dev / Railway single dyno).
# Format: redis://[:password@]host[:port]
REDIS_URL=
