{
    "env": {
        "node": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 12
    },
    "rules": {
        "no-console": [
            "warn",
            {
                "allow": [
                    "warn",
                    "error"
                ]
            }
        ],
        "no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^_",
                "varsIgnorePattern": "^_"
            }
        ],
        "no-restricted-imports": [
            "error",
            {
                "patterns": [
                    {
                        "group": [
                            "../controllers/*",
                            "../../controllers/*",
                            "**/controllers/*"
                        ],
                        "message": "🚫 LEGACY IMPORT: Use modules/ instead of controllers/. Import from src/modules/{domain}/"
                    }
                ]
            }
        ]
    }
}