# Vite App Environment Variables
# Note: Variables must start with VITE_ to be accessible in the browser

# API Configuration
VITE_API_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://localhost:8080
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Third-party Services
VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here
VITE_SENTRY_DSN=your_sentry_dsn_here

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Other Configuration
VITE_APP_NAME=Chttrix
VITE_VERSION=1.0.0

# Note: Never store sensitive secrets in client-side .env files
# as they will be exposed in the browser bundle!
