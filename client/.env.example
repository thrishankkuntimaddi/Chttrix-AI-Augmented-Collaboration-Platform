# React App Environment Variables
# Note: Variables must start with REACT_APP_ to be accessible in React

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=10000

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG=true

# Third-party Services
REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id_here
REACT_APP_SENTRY_DSN=your_sentry_dsn_here

# Other Configuration
REACT_APP_APP_NAME=Chttrix
REACT_APP_VERSION=1.0.0

# Note: Never store sensitive secrets in client-side .env files
# as they will be exposed in the browser bundle!
