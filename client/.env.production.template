# Production Environment Configuration for Chttrix Frontend

# Backend API URL (Your deployed backend domain)
# Example: https://api.yourdomain.com or https://your-backend.railway.app
VITE_BACKEND_URL=https://api.yourdomain.com

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Note: In production, Vite will automatically use the optimized build
# No need to set NODE_ENV here as it's handled by the build process
